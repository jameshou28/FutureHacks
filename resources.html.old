  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <h3>FutureHacks</h3>
          <p>A <a href="https://www.techshareproject.org/" target="_blank" rel="noopener">TechShareProject</a> initiative</p>
        </div>
        <div class="footer-links">
          <a href="https://www.instagram.com/techshareproject/" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/></svg>
