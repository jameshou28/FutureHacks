        <div class="video-card reveal">
          <div class="video-embed">
            <iframe src="[INTERMEDIATE VIDEO 3 EMBED URL]" title="[INTERMEDIATE VIDEO 3 TITLE]" frameborder="0" allowfullscreen></iframe>
