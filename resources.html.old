<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resources — FutureHacks</title>
  <meta name="description" content="Tutorial resources for FutureHacks participants">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;700&family=Karla:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
  <link rel="icon" href="assets/favicon.png" type="image/png">
  <link rel="shortcut icon" href="assets/favicon.png">
  <meta name="theme-color" content="#0f172a">
</head>
<body>
  <div class="grain" aria-hidden="true"></div>

  <!-- Navigation -->
  <nav class="navbar scrolled" id="navbar">
    <div class="nav-container">
      <a href="index.html" class="nav-logo">FutureHacks</a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-menu" id="navMenu">
        <li><a href="index.html#about">About</a></li>
        <li><a href="index.html#details">Details</a></li>
        <li><a href="index.html#schedule">Schedule</a></li>
        <li><a href="index.html#faq">FAQ</a></li>
        <li><a href="resources.html">Resources</a></li>
        <li><a href="/registration" class="nav-cta">Register</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero -->
  <section class="resources-hero">
    <div class="container">
      <span class="section-eyebrow reveal">Learning Resources</span>
      <h1 class="resources-title reveal">Find Your Level</h1>
      <p class="resources-subtitle reveal">Each category includes the rules and guidelines for your track, plus tutorial videos to help you build something great.</p>

      <!-- Category Jump Buttons -->
      <div class="category-jumps reveal">
        <a href="#beginner" class="category-jump category-jump--beginner">
          <span class="category-jump-label">Beginner</span>
          <svg class="category-jump-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#intermediate" class="category-jump category-jump--intermediate">
          <span class="category-jump-label">Intermediate</span>
          <svg class="category-jump-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#advanced" class="category-jump category-jump--advanced">
          <span class="category-jump-label">Advanced</span>
          <svg class="category-jump-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M10 4l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Beginner Section -->
  <section class="resources-section section" id="beginner">
    <div class="container">
      <div class="resources-section-header reveal">
        <h2 class="resources-section-title">Beginner</h2>
        <p class="resources-section-desc">New to coding? No problem. These tutorials cover the fundamentals and walk you through simple projects step by step.</p>
      </div>

      <!-- PDF Guidelines -->
      <div class="pdf-card reveal">
        <div class="pdf-card-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="2" width="16" height="22" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M4 7h16M8 12h8M8 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="14" y="16" width="10" height="10" rx="2" fill="currentColor" opacity="0.15"/>
            <path d="M19 18v4M17 20h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="pdf-card-info">
          <h3>Beginner Rules &amp; Guidelines</h3>
          <p>Read the full rules, judging criteria, and project requirements for the Beginner category before you start building.</p>
        </div>
        <a href="[BEGINNER PDF URL]" target="_blank" rel="noopener" class="pdf-card-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 2v8M5 7l3 3 3-3M2 11v1a2 2 0 002 2h8a2 2 0 002-2v-1" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          View PDF
        </a>
      </div>

      <!-- Tutorial Videos -->
      <h3 class="video-section-label reveal">Tutorial Videos</h3>
      <div class="video-grid">
        <div class="video-card reveal">
          <div class="video-embed">
            <iframe src="[BEGINNER VIDEO 1 EMBED URL]" title="[BEGINNER VIDEO 1 TITLE]" frameborder="0" allowfullscreen></iframe>
          </div>
          <div class="video-info">
            <h3>[BEGINNER VIDEO 1 TITLE]</h3>
            <p>[BEGINNER VIDEO 1 DESCRIPTION]</p>
          </div>
        </div>
        <div class="video-card reveal">
          <div class="video-embed">
            <iframe src="[BEGINNER VIDEO 2 EMBED URL]" title="[BEGINNER VIDEO 2 TITLE]" frameborder="0" allowfullscreen></iframe>
          </div>
          <div class="video-info">
            <h3>[BEGINNER VIDEO 2 TITLE]</h3>
            <p>[BEGINNER VIDEO 2 DESCRIPTION]</p>
          </div>
        </div>
        <div class="video-card reveal">
          <div class="video-embed">
            <iframe src="[BEGINNER VIDEO 3 EMBED URL]" title="[BEGINNER VIDEO 3 TITLE]" frameborder="0" allowfullscreen></iframe>
          </div>
          <div class="video-info">
            <h3>[BEGINNER VIDEO 3 TITLE]</h3>
            <p>[BEGINNER VIDEO 3 DESCRIPTION]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intermediate Section -->
  <section class="resources-section resources-section--alt section" id="intermediate">
    <div class="container">
      <div class="resources-section-header reveal">
        <h2 class="resources-section-title">Intermediate</h2>
        <p class="resources-section-desc">Have some experience? These tutorials tackle more complex projects and introduce new tools and concepts to push your skills further.</p>
      </div>

      <!-- PDF Guidelines -->
      <div class="pdf-card pdf-card--intermediate reveal">
        <div class="pdf-card-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="2" width="16" height="22" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="M4 7h16M8 12h8M8 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="14" y="16" width="10" height="10" rx="2" fill="currentColor" opacity="0.15"/>
            <path d="M19 18v4M17 20h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
