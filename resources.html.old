      <!-- Tutorial Videos -->
      <h3 class="video-section-label reveal">Tutorial Videos</h3>
      <div class="video-grid">
        <div class="video-card reveal">
          <div class="video-embed">
            <iframe src="[INTERMEDIATE VIDEO 1 EMBED URL]" title="[INTERMEDIATE VIDEO 1 TITLE]" frameborder="0" allowfullscreen></iframe>
